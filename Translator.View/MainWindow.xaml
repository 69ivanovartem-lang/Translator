<Window x:Class="Translator.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="Транслятор - Вариант 3"
        Width="1100"
        Height="650"
        mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Панель инструментов -->
        <ToolBar Grid.Row="0" Grid.ColumnSpan="2">
            <Button Command="{Binding OpenFileCommand}" Content="📂 Открыть"/>
            <Button Command="{Binding SaveFileCommand}" Content="💾 Сохранить исходник"/>
            <Separator/>
            <Button Command="{Binding CompileCommand}" Content="🔧 Компилировать" Background="LightGreen"/>
            <Button Command="{Binding CompileAndRunCommand}" Content="🚀 Компилировать и запустить в DOSBox" Background="LightBlue" FontWeight="Bold"/>
            <Separator/>
            <Button Command="{Binding SaveAsmCommand}" Content="💾 Сохранить ASM"/>
        </ToolBar>

        <!-- Заголовки -->
        <Label Grid.Row="1" Grid.Column="0" Content="📝 Исходный код (входная программа)" 
               FontWeight="Bold" HorizontalAlignment="Center" Margin="5"/>
        <Label Grid.Row="1" Grid.Column="1" Content="⚙️ Сгенерированный ASM код" 
               FontWeight="Bold" HorizontalAlignment="Center" Margin="5"/>

        <!-- Поле ввода исходного кода -->
        <TextBox Grid.Row="2" Grid.Column="0" Margin="10" 
                 AcceptsReturn="True" AcceptsTab="True"
                 FontSize="14" FontFamily="Consolas"
                 TextWrapping="NoWrap" Text="{Binding InputText}" 
                 VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Visible"/>

        <!-- Поле вывода ASM кода -->
        <TextBox Grid.Row="2" Grid.Column="1" Margin="10" 
                 FontSize="12" FontFamily="Consolas" IsReadOnly="True" 
                 Text="{Binding OutputText}" 
                 VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Visible"
                 Background="#F5F5F5"/>

        <!-- Статусная строка -->
        <StatusBar Grid.Row="3" Grid.ColumnSpan="2">
            <StatusBarItem>
                <TextBlock>✅ Готов к работе | DOSBox: D:\Translator\Translator\Translator.View\bin\Debug\net8.0-windows\DOSBox\DOSBox.exe</TextBlock>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>